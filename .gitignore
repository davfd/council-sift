# raw evidence is NEVER committed (images, E01, memory dumps)
evidence/

# derived tool output from the official organizer evidence — NOT redistributed.
# regenerate locally from the SIFT VM with scripts/pull_corpus_from_sift.sh
eval/corpus/

# NOTE: council/receipts/*.json ARE committed (canonical proof deliverables) — not ignored, so a
# clean orphan snapshot (PUBLISH.md Option B, git add -A) includes them without a force-add.

# Trusted execution captures can contain full official evidence stdout. They are local audit artifacts,
# not redistributable public corpus. Commit code/tests/docs, not captured stdout records.
council/executions/*.json
!council/executions/README.md

*.bak
*.tmp
.DS_Store

# full unredacted autonomous transcripts (local audit only)
*.raw.jsonl

# Local publication/audit scaffolding for preparing the Devpost snapshot.
# Keep these out of the public reports index; they are operator process notes,
# not case reports or judge-facing evidence.
reports/FIND-EVIL-PUBLIC-*.md
reports/FIND-EVIL-CLEAN-REPO-AUDIT.md

# Local/manual ROCBA casebuilding artifacts from exploratory SIFT digs.
# Public submission artifacts are the tracked demo reports, receipts, and execution logs;
# do not accidentally add operator scratch reports, one-off scripts, or Discord/Council drafts.
# The packaging plan is an operator handoff with local paths/status, not a Devpost artifact.
_drafts/
