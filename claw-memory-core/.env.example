# claw-memory .env.example
# Copy to .env and fill in real values; .env is gitignored.

# ── Neo4j connection ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── OpenAI (semantic_recall vector path + iter8 LoCoMo benchmark) ────────────
# Absent → semantic_recall falls back to text-pattern (R-spec-3 fallback path).
OPENAI_API_KEY=

# ── Item 11 (R67 close) — classifier LLM circuit-breaker timeout ─────────────
# Default 5000ms; Promise.race rejects + falls back to rule-based classification.
# CLAW_LLM_CLASSIFIER_TIMEOUT_MS=5000

# ── Item 26 (R70 close) — recall LIMIT default ──────────────────────────────
# Default 50; per-call params.limit overrides.
# CLAW_RECALL_LIMIT_DEFAULT=50

# ── R-spec-6 Phase 3 confidence decay (2026-05-22 — 5/5 ratified) ────────────
# Circuit breaker — OFF by default. Set to 'true' to enable applyConfidenceDecay()
# inside runDecayCron(). Path A authorization: classifier output is the ORIGIN;
# decay cron may adjust within ratified bounds per R-spec-6 R2 5/5.
CLAW_DECAY_CONFIDENCE_ENABLED=false

# Hybrid decay rate per cron pass (default 0.01).
# Formula: confidence_new = confidence × exp(-λ / max(1, N_recent_recalls))
# CLAW_DECAY_RATE_LAMBDA=0.01

# Recent-recall window for activity-weighted denominator (default 30 days).
# CLAW_DECAY_WINDOW_DAYS=30

# Cap on nodes processed per cron pass — cost ceiling for hourly cron (default 200).
# CLAW_DECAY_MAX_NODES_PER_PASS=200

# Cold-start protection — skip MCs younger than this (default 14 days).
# CLAW_DECAY_MIN_AGE_DAYS=14

# Decay floor — node stays 'active' at this confidence; NO archived transition
# (lifecycle-thresholds-v4.md §3 archived=RawEvent only). Default 0.10.
# CLAW_DECAY_CONFIDENCE_FLOOR=0.10

# Pre-wiring guard — for nodes that predate R37 OBSERVED_IN wiring (CF-G7c-G8
# closed 2026-05-15); zero-OBSERVED_IN nodes ingested before this date get
# effectiveRecallCount = max(1, rawCount) instead of being treated as fully
# stale. Prevents mass-decay on first CONFIDENCE_ENABLED=true flip.
# CLAW_DECAY_WIRING_BASELINE_DATE=2026-05-15
