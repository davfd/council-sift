{
  "name": "claw-memory",
  "version": "0.1.0",
  "description": "claw-memory semantic memory subsystem",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
