    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^20.19.1",
    "@xenova/transformers": "^2.17.2",
    "openai": "^5.10.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
