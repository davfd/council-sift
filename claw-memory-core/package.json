    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    },
    "./embeddings": {
      "import": "./dist/core/embeddings/embeddings.service.js",
      "types": "./dist/core/embeddings/embeddings.service.d.ts"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "neo4j-driver": "^5.28.1",
    "simple-statistics": "^7.8.9",
    "uuid": "^11.1.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
